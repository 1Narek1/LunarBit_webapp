  justify-content: center;
  flex-shrink: 0;
  margin-top: 2px;
}

.edu-step-text { flex: 1; }

.edu-tip {
  background: rgba(0,229,255,0.08);
  border: 1px solid rgba(0,229,255,0.2);
  border-radius: 8px;
  padding: 10px 12px;
  margin: 10px 0;
  font-size: 12px;
  color: var(--accent);
}

.edu-warning {
  background: rgba(255,23,68,0.08);
  border: 1px solid rgba(255,23,68,0.2);
  border-radius: 8px;
  padding: 10px 12px;
  margin: 10px 0;
  font-size: 12px;
  color: #ff6b6b;
}

.edu-example {
  background: var(--bg);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 12px;
  margin: 10px 0;
  font-family: monospace;
  font-size: 12px;
}

.edu-progress {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 16px;
}

.edu-progress-bar {
  flex: 1;
  height: 4px;
  background: var(--border);
  border-radius: 2px;
  overflow: hidden;
}

.edu-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--purple), var(--accent));
  border-radius: 2px;
  transition: width .3s;
}

.edu-progress-text {
  font-size: 11px;
  color: var(--muted);
  white-space: nowrap;
}

.profile-card {
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 16px;
  margin-bottom: 10px;
}

.profile-plan {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12px;
}

.plan-badge {
  padding: 6px 16px;
  border-radius: 20px;
  font-size: 14px;
  font-weight: 700;
}

.plan-free { background: rgba(100,116,139,0.2); color: var(--muted); }
.plan-basic { background: rgba(251,191,36,0.2); color: #fbbf24; }
.plan-pro { background: rgba(239,68,68,0.2); color: #ef4444; }

.profile-row {
  display: flex;
  justify-content: space-between;
  padding: 10px 0;
  border-bottom: 1px solid var(--border);
  font-size: 13px;
}

.profile-row:last-child { border-bottom: none; }
.profile-row .plbl { color: var(--muted); }
.profile-row .pval { font-family: monospace; font-weight: 600; }

.btn-primary {
  width: 100%;
  background: linear-gradient(135deg, var(--purple), var(--accent));
  color: white;
  border: none;
  border-radius: 12px;
  padding: 14px;
  font-size: 15px;
  font-weight: 700;
  cursor: pointer;
  margin-top: 10px;
}

.ref-box {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
  font-family: monospace;
  font-size: 11px;
  color: var(--accent);
  word-break: break-all;
  margin-top: 8px;
  cursor: pointer;
}

.lang-overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.8);
  z-index: 200;
  display: flex;
  align-items: center;
  justify-content: center;
}

.lang-modal {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 24px;
  width: 280px;
}

.lang-title {
  text-align: center;
  font-size: 18px;
  font-weight: 700;
  margin-bottom: 20px;
}

.lang-btn {
  width: 100%;
  background: var(--card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 14px;
  color: var(--text);
  font-size: 15px;
  cursor: pointer;
  margin-bottom: 8px;
  display: flex;
  align-items: center;
  gap: 10px;
}

.loading {
  text-align: center;
  padding: 40px;
  color: var(--muted);
  font-size: 13px;
}

.spinner {
  width: 28px; height: 28px;
  border: 2px solid var(--border);
  border-top-color: var(--accent);
  border-radius: 50%;
  animation: spin .8s linear infinite;
  margin: 0 auto 12px;
}

@keyframes spin { to { transform: rotate(360deg); } }
.empty { text-align: center; padding: 40px 20px; color: var(--muted); }
</style>
</head>
<body>

<div class="lang-overlay" id="langOverlay">
  <div class="lang-modal">
    <div class="lang-title">🌍 Choose Language</div>
    <button class="lang-btn" onclick="setLang('ru')">🇷🇺 Русский</button>
    <button class="lang-btn" onclick="setLang('en')">🇬🇧 English</button>
    <button class="lang-btn" onclick="setLang('am')">🇦🇲 Հայերեն</button>
  </div>
</div>

<!-- SPREADS -->
<div class="page active" id="pageSpreads">
  <div class="page-header">
    <div class="page-title">🌙 LunarBit</div>
    <div class="live-badge"><div class="dot"></div>Live</div>
  </div>
  <div class="stats-row">
    <div class="stat-card"><div class="stat-val" id="statTotal">—</div><div class="stat-lbl" id="lblSignals">Signals</div></div>
    <div class="stat-card"><div class="stat-val" id="statBest">—</div><div class="stat-lbl" id="lblBest">Best</div></div>
    <div class="stat-card"><div class="stat-val" id="statPlan">—</div><div class="stat-lbl" id="lblPlan">Plan</div></div>
  </div>
  <div class="filter-row">
    <button class="chip active" onclick="setFilter('all',this)" id="chipAll">All</button>
    <button class="chip" onclick="setFilter('cex',this)" id="chipCex">CEX</button>
    <button class="chip" onclick="setFilter('dex',this)" id="chipDex">DEX 🔒</button>
  </div>
  <div id="spreadsList"><div class="loading"><div class="spinner"></div><span id="lblLoading">Loading...</span></div></div>
</div>

<!-- CALCULATOR -->
<div class="page" id="pageCalc">
  <div class="page-header"><div class="page-title" id="lblCalcTitle">Calculator</div></div>
  <div class="calc-card">
    <div class="calc-label" id="lblCapital">Your capital (USDT)</div>
    <input class="calc-input" type="number" id="capitalInput" value="1000" oninput="calcUpdate()">
  </div>
  <div id="calcResults"><div class="empty" id="lblCalcEmpty">Enter capital</div></div>
</div>

<!-- EDUCATION -->
<div class="page" id="pageEdu">
  <div class="page-header"><div class="page-title" id="lblEduTitle">Education</div></div>
  <div class="edu-progress">
    <div class="edu-progress-bar"><div class="edu-progress-fill" id="eduProgressFill" style="width:0%"></div></div>
    <div class="edu-progress-text" id="eduProgressText">0/6</div>
  </div>
  <div id="eduContent"></div>
</div>

<!-- PROFILE -->
<div class="page" id="pageProfile">
  <div class="page-header"><div class="page-title" id="lblProfileTitle">Profile</div></div>
  <div class="profile-card">
    <div class="profile-plan">
      <div id="lblYourPlan">Your plan</div>
      <div class="plan-badge plan-free" id="planBadge">Free</div>
    </div>
    <div class="profile-row"><div class="plbl" id="lblExpires">Expires</div><div class="pval" id="profileExpires">—</div></div>
    <div class="profile-row"><div class="plbl" id="lblScans">Scans today</div><div class="pval" id="profileScans">—</div></div>
    <div class="profile-row"><div class="plbl" id="lblRefs">Friends invited</div><div class="pval" id="profileRefs">0</div></div>
  </div>
  <div class="profile-card">
    <div style="font-size:13px;color:var(--muted);margin-bottom:8px" id="lblRefLink">Referral link</div>
    <div class="ref-box" id="refLink" onclick="copyRef()">Loading...</div>
    <div style="font-size:11px;color:var(--muted);margin-top:6px;text-align:center" id="lblCopyHint">Tap to copy</div>
  </div>
  <button class="btn-primary" onclick="openBot()" id="btnOpenBot">🤖 Open Bot</button>
  <button class="btn-primary" style="margin-top:8px;background:linear-gradient(135deg,#f59e0b,#ef4444)" onclick="openPremium()" id="btnPremium">⭐ Premium</button>
  <button class="btn-primary" style="margin-top:8px;background:var(--surface);border:1px solid var(--border);color:var(--text)" onclick="showLangOverlay()" id="btnLang">🌍 Language</button>
</div>

<nav class="bottom-nav">
  <button class="nav-btn active" id="navSpreads" onclick="switchPage('Spreads')"><span class="nav-icon">📊</span><span id="navLblSpreads">Spreads</span></button>
  <button class="nav-btn" id="navCalc" onclick="switchPage('Calc')"><span class="nav-icon">🧮</span><span id="navLblCalc">Calc</span></button>
  <button class="nav-btn" id="navEdu" onclick="switchPage('Edu')"><span class="nav-icon">📚</span><span id="navLblEdu">Education</span></button>
  <button class="nav-btn" id="navProfile" onclick="switchPage('Profile')"><span class="nav-icon">👤</span><span id="navLblProfile">Profile</span></button>
</nav>

<script>
const tg = window.Telegram.WebApp;
tg.expand();
tg.setHeaderColor('#0a0e1a');
tg.setBackgroundColor('#0a0e1a');

const API = 'https://lunarbit-api.onrender.com';
const BOT = 'https://t.me/LunarBit_Bot';

let lang = localStorage.getItem('lb_lang') || null;
let userPlan = 'free';
let userData = {};
let spreadsData = [];
let activeFilter = 'all';
let userId = null;
let openedLessons = new Set();

const T = {
  ru: {
    signals:'Сигналов', best:'Лучший', plan:'План',
    loading:'Загружаем...', all:'Все', cex:'CEX',
    calcTitle:'🧮 Калькулятор', capital:'Ваш капитал (USDT)',
    calcEmpty:'Введите капитал для расчёта',
    eduTitle:'📚 Обучение', profileTitle:'👤 Профиль',
    yourPlan:'Ваш план', expires:'Истекает',
    scans:'Сканов сегодня', refs:'Приглашено друзей',
    refLink:'Реферальная ссылка', copyHint:'Нажмите чтобы скопировать',
    openBot:'🤖 Открыть LunarBit Bot', premium:'⭐ Перейти на Premium',
    changeLang:'🌍 Сменить язык',
    navSpreads:'Спреды', navCalc:'Калькулятор', navEdu:'Обучение', navProfile:'Профиль',
    buy:'Купить', sell:'Продать', spread:'Спред',
    profit:'Прибыль', fees:'Комиссии', net:'Чистая прибыль',
    lockedBasic:'⭐ Доступно в Basic', lockedPro:'🔥 Доступно в Pro',
    noOpps:'Возможностей пока нет', copied:'Скопировано!',
    planFree:'🆓 Free', planBasic:'⭐ Basic', planPro:'🔥 Pro',
    progress:'пройдено',
  },
  en: {
    signals:'Signals', best:'Best', plan:'Plan',
    loading:'Loading...', all:'All', cex:'CEX',
    calcTitle:'🧮 Calculator', capital:'Your capital (USDT)',
    calcEmpty:'Enter capital to see results',
    eduTitle:'📚 Education', profileTitle:'👤 Profile',
    yourPlan:'Your plan', expires:'Expires',
    scans:'Scans today', refs:'Friends invited',
    refLink:'Referral link', copyHint:'Tap to copy',
    openBot:'🤖 Open LunarBit Bot', premium:'⭐ Upgrade to Premium',
    changeLang:'🌍 Change Language',
    navSpreads:'Spreads', navCalc:'Calculator', navEdu:'Education', navProfile:'Profile',
    buy:'Buy', sell:'Sell', spread:'Spread',
    profit:'Profit', fees:'Fees', net:'Net profit',
    lockedBasic:'⭐ Available in Basic', lockedPro:'🔥 Available in Pro',
    noOpps:'No opportunities yet', copied:'Copied!',
    planFree:'🆓 Free', planBasic:'⭐ Basic', planPro:'🔥 Pro',
    progress:'completed',
  },
  am: {
    signals:'Ազդանշան', best:'Լավագույն', plan:'Պլան',
    loading:'Բեռնում...', all:'Բոլոր', cex:'CEX',
    calcTitle:'🧮 Հաշվիչ', capital:'Ձեր կապիտալ (USDT)',
    calcEmpty:'Մուտքագրեք կապիտալ',
    eduTitle:'📚 Կրթություն', profileTitle:'👤 Պրոֆիլ',
    yourPlan:'Ձեր պլանը', expires:'Լրանում է',
    scans:'Սկաններ այսօր', refs:'Հրավիրված ընկերներ',
    refLink:'Ռեֆերալային հղում', copyHint:'Սեղմել պատճենելու համար',
    openBot:'🤖 Բացել LunarBit Bot', premium:'⭐ Անցնել Premium',
    changeLang:'🌍 Փոխել լեզուն',
    navSpreads:'Սփրեդ', navCalc:'Հաշվիչ', navEdu:'Կրթություն', navProfile:'Պրոֆիլ',
    buy:'Գնել', sell:'Վաճառել', spread:'Սփրեդ',
    profit:'Շահույթ', fees:'Կոմիսիոն', net:'Մաքուր շահույթ',
    lockedBasic:'⭐ Հասանելի Basic-ում', lockedPro:'🔥 Հասանելի Pro-ում',
    noOpps:'Հնարավորություններ չկան', copied:'Պատճենված է!',
    planFree:'🆓 Free', planBasic:'⭐ Basic', planPro:'🔥 Pro',
    progress:'ավարտված',
  }
};

function t(key) { return (T[lang]||T['en'])[key]||key; }

// ── EDUCATION CONTENT ─────────────────────────────────────
const EDU = {
  ru: [
    {
      icon:'💡', color:'#7c3aed',
      title:'Основы арбитража',
      subtitle:'Что это и как работает',
      lessons: [
        {
          icon:'📖', title:'Что такое криптоарбитраж?',
          body:`
            <p>Арбитраж — это одна из старейших торговых стратегий в мире. Суть проста: <strong>купить дешевле в одном месте и продать дороже в другом</strong>.</p>

            <div class="edu-example">
Обычный рынок:
Яблоки на рынке А → 50 руб/кг
Яблоки на рынке Б → 70 руб/кг
Прибыль → 20 руб/кг (40%)
            </div>

            <p>В криптовалюте то же самое, но вместо рынков — биржи, а вместо яблок — Bitcoin, Ethereum и другие монеты.</p>

            <div class="edu-example">
Криптоарбитраж:
BTC на Binance  → $67,234
BTC на Bybit    → $67,891
Разница         → $657 (0.97%)
            </div>

            <p>Главное преимущество арбитража перед обычной торговлей — <strong>отсутствие рыночного риска</strong>. Вам не важно куда пойдёт цена, вы зарабатываете на разнице между биржами прямо сейчас.</p>

            <div class="edu-tip">💡 Арбитраж существует потому что рынок не идеален — разные биржи имеют разных пользователей, разный спрос и предложение.</div>
          `
        },
        {
          icon:'🔍', title:'Почему цены разные на биржах?',
          body:`
            <p>Многие новички удивляются: если Bitcoin один, почему цена разная? Вот причины:</p>

            <div class="edu-step"><div class="edu-step-num">1</div><div class="edu-step-text"><strong>Разная ликвидность</strong> — на Binance торгуют миллионы людей, на маленькой бирже — тысячи. Большой объём = более точная цена.</div></div>

            <div class="edu-step"><div class="edu-step-num">2</div><div class="edu-step-text"><strong>Разная география</strong> — азиатские биржи могут реагировать на новости быстрее, чем европейские.</div></div>

            <div class="edu-step"><div class="edu-step-num">3</div><div class="edu-step-text"><strong>Разные маркетмейкеры</strong> — каждая биржа имеет своих поставщиков ликвидности с разными ценами.</div></div>

            <div class="edu-step"><div class="edu-step-num">4</div><div class="edu-step-text"><strong>Задержка арбитражеров</strong> — пока боты выравнивают цены, образуется временная разница.</div></div>

            <div class="edu-tip">💡 Чем меньше биржа и менее популярна монета — тем больше ценовые расхождения.</div>

            <div class="edu-warning">⚠️ Спреды существуют секунды или минуты. Нужно действовать быстро!</div>
          `
        },
        {
          icon:'📊', title:'Виды арбитража',
          body:`
            <p>Существует несколько видов арбитража. Каждый имеет свои плюсы и минусы:</p>

            <p><strong>1. Межбиржевой (CEX-CEX)</strong></p>
            <p>Покупка на одной централизованной бирже, продажа на другой.</p>
            <div class="edu-example">Binance → Bybit → OKX → KuCoin</div>
            <p>✅ Просто | ✅ Быстро | ❌ Маленький спред (0.1-0.5%)</p>

            <br><p><strong>2. CEX-DEX арбитраж</strong></p>
            <p>Покупка на централизованной бирже, продажа на децентрализованной (или наоборот).</p>
            <div class="edu-example">Binance → Uniswap (Ethereum)
Binance → Raydium (Solana)</div>
            <p>✅ Больший спред (0.5-3%) | ❌ Нужен кошелёк | ❌ Gas fees</p>

            <br><p><strong>3. Треугольный арбитраж</strong></p>
            <p>Торговля тремя парами на одной бирже.</p>
            <div class="edu-example">BTC → ETH → USDT → BTC</div>
            <p>✅ Нет переводов между биржами | ❌ Сложнее рассчитать</p>

            <br><p><strong>4. Фандинг арбитраж</strong></p>
            <p>Получение выплат за ставку финансирования фьючерсов.</p>
            <p>✅ Стабильный доход | ✅ Минимальный риск | ❌ Нужен капитал</p>

            <div class="edu-tip">💡 LunarBit поддерживает CEX-CEX и CEX-DEX арбитраж. Фандинг — в разработке!</div>
          `
        }
      ]
    },
    {
      icon:'📊', color:'#0891b2',
      title:'Анализ и выбор возможностей',
      subtitle:'Как читать данные и выбирать сделки',
      lessons: [
        {
          icon:'📈', title:'Как читать спред?',
          body:`
            <p>Спред — это разница в цене между двумя биржами, выраженная в процентах.</p>

            <div class="edu-example">
Формула:
Спред = (Цена продажи - Цена покупки) / Цена покупки × 100%

Пример:
Покупка ETH на Binance:  $3,450
Продажа ETH на Bybit:    $3,484
Спред = (3484 - 3450) / 3450 × 100% = 0.99%
            </div>

            <p><strong>Какой спред считается хорошим?</strong></p>

            <div class="edu-step"><div class="edu-step-num">❌</div><div class="edu-step-text"><strong>0.0 - 0.2%</strong> — убыточно. Комиссии съедят всё.</div></div>
            <div class="edu-step"><div class="edu-step-num">⚠️</div><div class="edu-step-text"><strong>0.2 - 0.4%</strong> — минимальная прибыль. Риск не оправдан.</div></div>
            <div class="edu-step"><div class="edu-step-num">✅</div><div class="edu-step-text"><strong>0.4 - 0.8%</strong> — хорошая возможность. Стоит рассмотреть.</div></div>
            <div class="edu-step"><div class="edu-step-num">🔥</div><div class="edu-step-text"><strong>0.8%+</strong> — отличная возможность. Действовать быстро!</div></div>

            <div class="edu-warning">⚠️ Всегда вычитайте комиссии! Типичные комиссии: 0.1% покупка + 0.1% продажа = 0.2% итого.</div>
          `
        },
        {
          icon:'🎯', title:'Как выбрать монету для арбитража?',
          body:`
            <p>Не все монеты одинаково подходят для арбитража. Вот критерии выбора:</p>

            <p><strong>✅ Хорошие кандидаты:</strong></p>
            <div class="edu-step"><div class="edu-step-num">1</div><div class="edu-step-text"><strong>Высокий объём торгов</strong> — минимум $10 млн/день. Вы сможете купить и продать быстро.</div></div>
            <div class="edu-step"><div class="edu-step-num">2</div><div class="edu-step-text"><strong>Листинг на 3+ биржах</strong> — больше бирж = больше возможностей для арбитража.</div></div>
            <div class="edu-step"><div class="edu-step-num">3</div><div class="edu-step-text"><strong>Открытый вывод</strong> — монета должна свободно выводиться на обеих биржах.</div></div>
            <div class="edu-step"><div class="edu-step-num">4</div><div class="edu-step-text"><strong>Быстрая сеть</strong> — Solana (0.4 сек), BSC (3 сек) лучше чем Ethereum (15 сек+).</div></div>

            <p><strong>❌ Избегайте:</strong></p>
            <p>• Новые монеты (листинг менее 3 месяцев)</p>
            <p>• Монеты с ограниченным выводом</p>
            <p>• Малоликвидные токены (объём менее $1 млн/день)</p>
            <p>• Мем-коины без реального использования</p>

            <div class="edu-tip">💡 Лучшие монеты для начала: BTC, ETH, SOL, BNB, XRP — высокая ликвидность, быстрый вывод.</div>
          `
        },
        {
          icon:'⏰', title:'Когда лучше торговать?',
          body:`
            <p>Время имеет значение. Спреды не одинаковы в разное время суток и при разных условиях рынка.</p>

            <p><strong>🔥 Лучшее время для арбитража:</strong></p>

            <div class="edu-step"><div class="edu-step-num">1</div><div class="edu-step-text"><strong>Во время волатильности</strong> — когда цена резко движется вверх или вниз, биржи не успевают синхронизироваться. Спреды увеличиваются.</div></div>

            <div class="edu-step"><div class="edu-step-num">2</div><div class="edu-step-text"><strong>Азиатская сессия (02:00-10:00 МСК)</strong> — азиатские биржи активны, западные спят. Ценовые расхождения выше.</div></div>

            <div class="edu-step"><div class="edu-step-num">3</div><div class="edu-step-text"><strong>После крупных новостей</strong> — новости о регуляции, хардфорке, листинге создают временные дисбалансы.</div></div>

            <div class="edu-step"><div class="edu-step-num">4</div><div class="edu-step-text"><strong>Конец месяца/квартала</strong> — институциональные игроки закрывают позиции, создавая аномалии.</div></div>

            <div class="edu-example">
Пример: Новость о листинге токена на Coinbase
До новости:  $1.20 (на всех биржах)
После на Coinbase: $1.45 (+20%)
На других биржах: $1.22 (+1.6%)
Арбитраж: купить везде → продать на Coinbase
            </div>

            <div class="edu-tip">💡 Используйте /monitor в LunarBit — бот работает 24/7 и поймает возможность пока вы спите!</div>
          `
        }
      ]
    },
