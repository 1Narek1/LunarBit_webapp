// ── INIT ─────────────────────────────────────────────────
window.onload = async () => {
  if (tg.initDataUnsafe?.user) {
    userId = tg.initDataUnsafe.user.id;
  }
  if (!lang) {
    document.getElementById('langOverlay').style.display = 'flex';
  } else {
    init();
  }
};

function setLang(l) {
  lang = l;
  localStorage.setItem('lb_lang', l);
  document.getElementById('langOverlay').style.display = 'none';
  init();
}

function showLangOverlay() {
  document.getElementById('langOverlay').style.display = 'flex';
}

async function init() {
  applyTranslations();
  renderEdu();
  await loadUser();
  await loadSpreads();
  calcUpdate();
  setInterval(loadSpreads, 30000);
}

function applyTranslations() {
  const ids = {
    lblSignals:'signals', lblBest:'best', lblPlan:'plan',
    lblLoading:'loading', chipAll:'all', chipCex:'cex',
    lblCalcTitle:'calcTitle', lblCapital:'capital', lblCalcEmpty:'calcEmpty',
    lblEduTitle:'eduTitle', lblProfileTitle:'profileTitle',
    lblYourPlan:'yourPlan', lblExpires:'expires', lblScans:'scans',
    lblRefs:'refs', lblRefLink:'refLink', lblCopyHint:'copyHint',
    btnOpenBot:'openBot', btnPremium:'premium', btnLang:'changeLang',
    navLblSpreads:'navSpreads', navLblCalc:'navCalc',
    navLblEdu:'navEdu', navLblProfile:'navProfile',
  };
  for (const [id, key] of Object.entries(ids)) {
    const el = document.getElementById(id);
    if (el) el.textContent = t(key);
  }
  document.getElementById('chipDex').textContent = 'DEX 🔒';
}

async function loadUser() {
  if (!userId) return;
  try {
    const r = await fetch(`${API}/api/user/${userId}`);
    userData = await r.json();
    userPlan = userData.plan || 'free';

    const planNames = {free:t('planFree'), basic:t('planBasic'), pro:t('planPro')};
    document.getElementById('statPlan').textContent = planNames[userPlan] || 'Free';

    const badge = document.getElementById('planBadge');
    badge.textContent = planNames[userPlan] || 'Free';
    badge.className = `plan-badge plan-${userPlan}`;

    document.getElementById('profileExpires').textContent = userData.expires || '—';
    document.getElementById('profileScans').textContent = userData.scan_count || 0;
    document.getElementById('profileRefs').textContent = userData.ref_count || 0;
    document.getElementById('refLink').textContent = `https://t.me/LunarBit_Bot?start=REF${userId}`;
  } catch(e) {}
}

async function loadSpreads() {
  try {
    const url = userId ? `${API}/api/spreads?user_id=${userId}` : `${API}/api/spreads`;
    const r = await fetch(url);
    const data = await r.json();
    spreadsData = data.spreads || [];
    document.getElementById('statTotal').textContent = spreadsData.filter(s=>!s.locked).length;
    const best = spreadsData.find(s=>!s.locked);
    document.getElementById('statBest').textContent = best ? `+${best.spread.toFixed(2)}%` : '—';
    renderSpreads();
    calcUpdate();
  } catch(e) {
    document.getElementById('spreadsList').innerHTML = `<div class="empty">${t('noOpps')}</div>`;
  }
}

async function refreshSpreads() {
  document.getElementById('spreadsList').innerHTML = `<div class="loading"><div class="spinner"></div><span>${t('loading')}</span></div>`;
  await loadSpreads();
}

function setFilter(f, btn) {
  activeFilter = f;
  document.querySelectorAll('.chip').forEach(c=>c.classList.remove('active'));
  btn.classList.add('active');
  renderSpreads();
}

function renderSpreads() {
  const list = document.getElementById('spreadsList');
  let data = spreadsData;
  if (activeFilter==='cex') data = data.filter(s=>!s.is_dex);
  if (activeFilter==='dex') data = data.filter(s=>s.is_dex);

  if (!data.length) {
    list.innerHTML = `<div class="empty">${t('noOpps')}</div>`;
    return;
  }

  list.innerHTML = data.slice(0,30).map(s => {
    const hot = s.spread >= 0.8;
    const lockText = s.lock_reason==='pro' ? t('lockedPro') : t('lockedBasic');
    return `<div class="opp-card${hot?' hot':''}">
      <div class="opp-top">
        <div class="opp-pair">${s.sym}/USDT${hot?' 🔥':''}</div>
        <div class="opp-spread">+${s.spread.toFixed(2)}%</div>
      </div>
      <div class="opp-route">
        <span class="ex-badge">${s.buy_ex}</span>
        <span style="color:#64748b">→</span>
        <span class="ex-badge" style="color:#00e676">${s.sell_ex}</span>
      </div>
      <div class="opp-prices">
        <div class="price-item"><div class="plbl">${t('buy')}</div><div class="pval">$${formatP(s.buy_p)}</div></div>
        <div class="price-item"><div class="plbl">${t('sell')}</div><div class="pval">$${formatP(s.sell_p)}</div></div>
      </div>
      ${s.locked?`<div class="lock-overlay" onclick="openPremium()"><div class="lock-icon">🔒</div><div class="lock-text">${lockText}</div></div>`:''}
    </div>`;
  }).join('');
}

function calcUpdate() {
  const capital = parseFloat(document.getElementById('capitalInput').value)||0;
  const container = document.getElementById('calcResults');
  if (!capital||!spreadsData.length) {
    container.innerHTML=`<div class="empty">${t('calcEmpty')}</div>`;
    return;
  }
  const unlocked = spreadsData.filter(s=>!s.locked).slice(0,5);
  if (!unlocked.length) {
    container.innerHTML=`<div class="empty">${t('noOpps')}</div>`;
    return;
  }
  container.innerHTML = unlocked.map(s=>{
    const gross = s.spread/100*capital;
    const fees = capital*0.002;
    const net = gross-fees;
    return `<div class="calc-result">
      <div style="font-weight:700;margin-bottom:8px">${s.sym}/USDT</div>
      <div class="calc-row"><div class="label">${t('spread')}</div><div class="value">+${s.spread.toFixed(2)}%</div></div>
      <div class="calc-row"><div class="label">${t('profit')}</div><div class="value yellow">$${gross.toFixed(2)}</div></div>
      <div class="calc-row"><div class="label">${t('fees')}</div><div class="value" style="color:var(--red)">-$${fees.toFixed(2)}</div></div>
      <div class="calc-row"><div class="label">${t('net')}</div><div class="value ${net>0?'green':''}">${net>0?'+':''}$${net.toFixed(2)}</div></div>
    </div>`;
  }).join('');
}

function renderEdu() {
  const modules = EDU[lang]||EDU['en'];
  const total = modules.reduce((s,m)=>s+m.lessons.length,0);

  document.getElementById('eduContent').innerHTML = modules.map((m,mi)=>`
    <div class="edu-module" id="mod${mi}">
      <div class="edu-module-header" onclick="toggleModule(${mi})">
        <div class="edu-module-left">
          <div class="edu-module-icon" style="background:${m.color}22;border:1px solid ${m.color}44">${m.icon}</div>
          <div>
            <div class="edu-module-title">${m.title}</div>
            <div class="edu-module-subtitle">${m.subtitle} • ${m.lessons.length} ${lang==='am'?'դաս':lang==='ru'?'урока':'lessons'}</div>
          </div>
        </div>
        <div class="edu-module-arrow">›</div>
      </div>
      <div class="edu-module-body">
        ${m.lessons.map((l,li)=>`
          <div class="edu-lesson" id="les${mi}_${li}">
            <div class="edu-lesson-header" onclick="toggleLesson(${mi},${li})">
              <div class="edu-lesson-title">${l.icon} ${l.title}</div>
              <div class="edu-lesson-arrow">›</div>
            </div>
            <div class="edu-lesson-body">${l.body}</div>
          </div>
        `).join('')}
      </div>
    </div>
  `).join('');

  updateProgress(total);
}

function toggleModule(i) {
  document.getElementById(`mod${i}`).classList.toggle('open');
}

function toggleLesson(mi, li) {
  const les = document.getElementById(`les${mi}_${li}`);
  les.classList.toggle('open');
  if (les.classList.contains('open')) {
    openedLessons.add(`${mi}_${li}`);
  }
  const modules = EDU[lang]||EDU['en'];
  const total = modules.reduce((s,m)=>s+m.lessons.length,0);
  updateProgress(total);
}

function updateProgress(total) {
  const pct = total>0 ? Math.round(openedLessons.size/total*100) : 0;
  document.getElementById('eduProgressFill').style.width = pct+'%';
  document.getElementById('eduProgressText').textContent = `${openedLessons.size}/${total} ${t('progress')}`;
}

function switchPage(name) {
  ['Spreads','Calc','Edu','Profile'].forEach(p=>{
    document.getElementById(`page${p}`).classList.remove('active');
    document.getElementById(`nav${p}`).classList.remove('active');
  });
  document.getElementById(`page${name}`).classList.add('active');
  document.getElementById(`nav${name}`).classList.add('active');
}

function formatP(p) {
  if (!p) return '—';
  if (p>=1000) return p.toLocaleString('en',{minimumFractionDigits:2,maximumFractionDigits:2});
  if (p>=1) return p.toFixed(4);
  return p.toFixed(6);
}

function openBot() { tg.openTelegramLink(BOT); }
function openPremium() { tg.openTelegramLink(`${BOT}`); }

function copyRef() {
  const text = document.getElementById('refLink').textContent;
  navigator.clipboard.writeText(text).then(()=>{
    tg.showAlert(t('copied'));
  }).catch(()=>{
    tg.showAlert(text);
  });
}
</script>
</body>
</html>
